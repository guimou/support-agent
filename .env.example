# LiteMaaS Agent Assistant — Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# === Required ===

# Letta agent runtime URL
LETTA_SERVER_URL=http://letta:8283

# LiteMaaS backend API base URL
LITEMAAS_API_URL=http://host.containers.internal:8081

# JWT shared secret (must match LiteMaaS JWT_SECRET, HS256)
JWT_SECRET=

# --- LLM Providers (power the agent and guardrails) ---

# Agent reasoning model — uses Letta provider prefix (e.g. openai-proxy/MyModel)
AGENT_MODEL=
AGENT_LLM_API_BASE=
AGENT_LLM_API_KEY=

# Guardrails classification model — plain model name, no provider prefix
# (guardrails call the LLM provider directly, not through Letta)
GUARDRAILS_MODEL=
GUARDRAILS_LLM_API_BASE=
GUARDRAILS_LLM_API_KEY=

# --- Monitored LiteLLM Instance (queried by tools) ---

# LiteLLM proxy base URL (the platform instance we help users with)
LITELLM_API_URL=http://host.containers.internal:4000

# LiteLLM master key (admin tools calling LiteLLM endpoints)
LITELLM_API_KEY=

# LiteLLM scoped read-only key (standard user tools)
LITELLM_USER_API_KEY=

# LiteMaaS admin API key (admin tools calling LiteMaaS backend endpoints)
LITEMAAS_ADMIN_API_KEY=

# === Optional ===

# JWT issuer claim validation (empty = skip validation)
# JWT_ISSUER=litemaas

# JWT audience claim validation (empty = skip validation)
# JWT_AUDIENCE=litemaas-agent

# Proxy server port (default: 8400)
# PROXY_PORT=8400

# Logging level (default: info)
# LOG_LEVEL=info

# Path to initial knowledge docs for archival memory seeding
# MEMORY_SEED_PATH=

# CORS allowed origins (default: * — restrict in production)
# CORS_ORIGINS=*

# Output rail chunk size in tokens for streaming evaluation (default: 200)
# OUTPUT_RAIL_CHUNK_SIZE=200

# Token overlap between chunks for context continuity (default: 50)
# OUTPUT_RAIL_OVERLAP=50

# Per-user chat requests per minute (default: 30)
# RATE_LIMIT_RPM=30

# Per-user memory write operations per hour (default: 20)
# RATE_LIMIT_MEMORY_WRITES_PER_HOUR=20
