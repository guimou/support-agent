# Content safety rails (Colang 1.0)
# Bot response definitions and regex-based pre-filter flows.
# Input safety (jailbreak, off-topic) is handled outside NeMo by
# Llama Guard + agent-model topic classifier in rails.py.

define bot refuse unsafe output
  "I apologize, but I'm unable to provide that information. Is there something else about the LiteMaaS platform I can help you with?"

define flow check output safety
  $allowed = execute regex_check_output_pii
  if not $allowed
    bot refuse unsafe output
    stop
